{"openapi":"3.1.0","info":{"title":"EU Building Energy Compliance API","description":"Engineering-grade EPBD 2024/1275 compliance analysis for European buildings. EPC label class per national transposition (GEG/DPE/RD390/APE/NTA8800). MEPS worst-performing 15% screening per EPBD Article 7. EN ISO 52000-1:2017 primary energy methodology. Solar obligation per EPBD Article 9 / Annex III. Renovation Passport per EPBD Article 12 / Annex VIII (BRP). SFDR PAI 18 & 19 export (Delegated Regulation EU 2022/1288 Annex I Table 3). Lender underwriting pack (ECB Climate Risk Guide; LMA Green Loan Principles 2023). Refinancing risk flag (ESRB/2022/3; ECB climate risk guidance). Embodied carbon (ICE Database v3.0; EN 15978:2011; CSRD ESRS E1). Covers Germany, France, Spain, Italy, Netherlands, Poland, Sweden, UK. Every output equation cited to its primary regulatory or academic source.","version":"2.0.0"},"paths":{"/health":{"get":{"summary":"Health","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/pricing":{"get":{"summary":"Pricing","operationId":"pricing_pricing_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/analyse/quick":{"post":{"summary":"Quick EPC estimate and MEPS flag from monthly energy bill","description":"Quick screening from monthly energy cost.\n\nEstimates annual kWh from bill using EU commercial electricity price\n(Eurostat nrg_pc_205 H2 2023) and country-typical electricity fraction\n(JRC BSO 2023). Runs EN ISO 52000-1 primary energy calculation and\nreturns EPC label estimate + EPBD MEPS compliance flag.\n\nFree plan. Use /analyse/full with actual kWh meter data for precise results.","operationId":"analyse_quick_analyse_quick_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/QuickAnalysisRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/full":{"post":{"summary":"Full EN ISO 52000-1 EPBD compliance analysis with renovation roadmap","description":"Full EPBD compliance analysis. Pro plan required.\n\nDelivers:\n- EN ISO 52000-1:2017 delivered and primary energy calculation\n- National EPC label (GEG/DPE/RD390/APE/NTA 8800/BBR) with label scale\n- Climate-adjusted EU median benchmark (JRC BSO 2023)\n- Carbon intensity kgCO2e/m²/yr with national grid emission factor\n- EPBD 2024 Article 7 MEPS compliance — 2030 and 2033 deadlines\n- EPBD Article 9 / Annex III solar obligation screening\n- Renovation gap calculation (JRC TABULA archetypes)\n- Country incentive/grant programme stacking with net cost estimate","operationId":"analyse_full_analyse_full_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/FullAnalysisRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/portfolio":{"post":{"summary":"Portfolio screening — up to 20 buildings ranked by EPBD penalty exposure","description":"Portfolio analysis for real estate fund managers, ESG teams, and\nproperty consultants. Pro plan required. Up to 20 assets per call.\n\nReturns per-asset EPBD compliance summary ranked by estimated 2030\npenalty exposure (highest risk first), plus portfolio totals:\n- Total floor area\n- Total estimated renovation CAPEX\n- Maximum available grants across portfolio\n- Assets by MEPS compliance status\n- Total portfolio carbon intensity (kgCO2e/m²/yr weighted average)","operationId":"analyse_portfolio_analyse_portfolio_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PortfolioRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/reference/countries":{"get":{"summary":"Ref Countries","description":"Country data: EPC system, grid emission factor, PEF, HDD, nZEB threshold, incentives.","operationId":"ref_countries_reference_countries_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/reference/building-types":{"get":{"summary":"Ref Building Types","description":"Building types with EU median EUI benchmarks (JRC BSO 2023).","operationId":"ref_building_types_reference_building_types_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/reference/epc-thresholds":{"get":{"summary":"Ref Epc Thresholds","description":"EPC label thresholds by country — primary energy kWh/m²/yr.","operationId":"ref_epc_thresholds_reference_epc_thresholds_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/reference/renovation-measures":{"get":{"summary":"Ref Renovation Measures","description":"Renovation measure library with cost benchmarks and engineering sources.","operationId":"ref_renovation_measures_reference_renovation_measures_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/reference/methodology":{"get":{"summary":"Ref Methodology","description":"Full engineering methodology and primary source citations.","operationId":"ref_methodology_reference_methodology_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/analyse/stranding-risk":{"post":{"summary":"Years-to-stranding per country MEPS enforcement timeline","description":"Stranding Risk Clock — the product's executive dashboard metric.\n\nGiven a building's current EPC label, returns:\n- Exact year when this building becomes non-compliant under its country's\n  MEPS enforcement schedule (EPBD 2024 + national gold-plating)\n- Risk tier: stranded_now / critical / high / medium / low / compliant\n- Per-milestone compliance table (all known enforcement deadlines)\n- Asset value at risk (EUR) if annual NOI provided\n\nKey country-specific enforcement dates covered:\n  NL: EPC C already mandatory for offices since Jan 2023 (kantoreneis)\n  UK: EPC E mandatory for all commercial lettings (MEES 2023); C by 2027\n  FR: Décret Tertiaire 40% reduction by 2030 (stricter than EPBD baseline)\n  DE/ES/IT/PL: EPBD baseline 2030 (EPC E) and 2033 (EPC D)\n\nFree plan.","operationId":"analyse_stranding_risk_analyse_stranding_risk_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/StrandingRiskRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/renovation-sandbox":{"post":{"summary":"Toggle retrofit measures → live EPC recalculation + compliance date shift","description":"Renovation Sandbox — the asset manager's scenario modelling tool.\n\nSelect any combination of renovation measures. The engine:\n1. Applies measures sequentially using BPIE interaction methodology\n   (each measure reduces remaining load, avoiding double-counting)\n2. Recalculates primary EUI per EN ISO 52000-1\n3. Recalculates EPC label and MEPS compliance status\n4. Recalculates stranding year (stranding deferral = years bought)\n5. Returns value uplift if NOI provided (JLL Green Premium study)\n\nHeat pump modelled accurately: gas eliminated, electricity increases by\ngas_kWh / COP (COP=3.5 per EN 14825:2022). This is the critical\ndetail most tools get wrong — replacing gas boiler with heat pump\nincreases electricity demand but dramatically cuts primary energy\nbecause electricity PEF < gas PEF in most EU countries.\n\nPro plan required.","operationId":"analyse_renovation_sandbox_analyse_renovation_sandbox_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RenovationSandboxRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/solar-screening":{"post":{"summary":"EPBD Article 9 solar obligation scorecard for acquisitions","description":"Solar Obligation Scorecard — clean one-page verdict for developers\nand acquisitions teams.\n\nReturns:\n- Is solar installation MANDATORY? Under which law? By when?\n- Minimum required capacity (kWp) per country transposition\n- Full potential capacity and annual yield (PVGIS-SARAH2 irradiance)\n- Self-consumption offset % vs annual electricity demand\n- LCOE (EUR/kWh) — 25yr model, Jordan & Kurtz 2013 degradation\n\nEPBD Article 9 obligations vary significantly by country:\n  NL: new non-residential > 100 m² (strictest)\n  FR: new non-residential > 1,000 m²\n  DE: new non-residential > 50 kWp obligation (state laws also apply)\n  ES: new non-residential > 250 m²\n\nFree plan.","operationId":"analyse_solar_screening_analyse_solar_screening_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SolarScreeningRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/brown-discount":{"post":{"summary":"Acquisition due diligence — CAPEX liability + adjusted bid price","description":"Brown Discount Calculator — the acquisitions team's underwriting tool.\n\nComputes the total compliance liability embedded in a non-compliant\nbuilding purchase, with three components:\n\n1. Renovation CAPEX (net of available grants)\n   Source: JRC TABULA archetypes + country incentive programmes\n\n2. Cumulative penalty liability (2025–2030)\n   Source: BPIE MEPS Penalty Benchmarking 2024 — €100/m²/yr mid-estimate\n\n3. Cap rate expansion discount\n   Non-compliant buildings trade at 125–200bps wider cap rates.\n   Source: JLL Green Premium / Brown Discount EU Study 2023\n           CBRE ESG Pricing in European Real Estate Q4 2024\n\nOutput: recommended bid price = asking_price - total_brown_discount\n\nUse case: \"We are bidding on a German office at €12M. The building is\nEPC F. Our engine returns: Renovation CAPEX €680k (net of BEG grants),\nPenalty liability €250k, Cap rate discount €1.4M. Recommended bid: €9.67M.\"\n\nPro plan required.","operationId":"analyse_brown_discount_analyse_brown_discount_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/BrownDiscountRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/reference/meps-timelines":{"get":{"summary":"Full MEPS enforcement schedule per country","description":"Country-by-country MEPS enforcement timelines.\n\nIncludes EPBD baseline deadlines AND national gold-plating:\n- Netherlands: EPC C already mandatory for offices since Jan 2023\n- UK: MEES commercial EPC E in force; C by 2027 (consultation)\n- France: Décret Tertiaire 40% energy reduction by 2030\n- Germany/Spain/Italy/Poland: EPBD 2030 (EPC E) and 2033 (EPC D) baseline\n\nUse this to understand which countries have the most imminent enforcement.","operationId":"ref_meps_timelines_reference_meps_timelines_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/analyse/renovation-passport":{"post":{"tags":["Pro Analysis"],"summary":"Building Renovation Passport — EPBD Art.12 Annex VIII","description":"Generate a Building Renovation Passport per EPBD 2024/1275 Article 12 + Annex VIII.\nAll EU Member States must establish BRP scheme by 29 May 2026.\nReturns staged renovation roadmap, fossil-fuel phase-out schedule,\nenergy/carbon/cost savings per phase, grant funding, and ZEB pathway.\n**Pro plan required.**","operationId":"analyse_renovation_passport_analyse_renovation_passport_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RenovationPassportRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/refinancing-risk":{"post":{"tags":["Pro Analysis"],"summary":"Refinancing Risk — EPC stranding vs loan maturity flag","description":"Flag EPC-conditioned refinancing risk when stranding year ≤ loan maturity.\nReturns risk level, LTV impact, margin step-up estimate, and recommended\nlending conditions. **Pro plan required.**","operationId":"analyse_refinancing_risk_analyse_refinancing_risk_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RefinancingRiskRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/sfdr-pai":{"post":{"tags":["Pro Analysis"],"summary":"SFDR PAI 18 & 19 Export — real estate fund disclosure","description":"Generate SFDR Principal Adverse Impact disclosure data for real estate portfolios.\nPAI 18 (energy performance) + PAI 19 (fossil fuel exposure) per\nCommission Delegated Regulation (EU) 2022/1288 Annex I Table 3.\n**Pro plan required.**","operationId":"analyse_sfdr_pai_analyse_sfdr_pai_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SFDRPAIRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/lender-pack":{"post":{"tags":["Pro Analysis"],"summary":"Lender Underwriting Pack — EPC risk for credit committee","description":"Generate a structured EPC risk underwriting pack for lenders.\nReturns brown discount, LTV at prime/secondary cap rates, penalty liability,\nDSCR note, and recommended loan conditions.\n**Pro plan required.**","operationId":"analyse_lender_pack_analyse_lender_pack_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/LenderPackRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/embodied-carbon":{"post":{"tags":["Pro Analysis"],"summary":"Embodied Carbon — Scope 3 renovation materials (ICE v3.0)","description":"Estimate Scope 3 embodied carbon from renovation measures using ICE Database v3.0.\nCovers CSRD ESRS E1-6, SBTi Buildings pathway, and EU Taxonomy whole-life GWP.\n**Pro plan required.**","operationId":"analyse_embodied_carbon_analyse_embodied_carbon_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/EmbodiedCarbonRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/analyse/batch-portfolio":{"post":{"tags":["Pro Analysis"],"summary":"Batch Portfolio — up to 100 buildings, full stranding + refinancing risk","description":"Run full stranding risk + refinancing risk across up to 100 buildings in one call.\nReturns ranked portfolio by risk, SFDR PAI summary, and per-asset detail.\n**Pro plan required.**","operationId":"analyse_batch_portfolio_analyse_batch_portfolio_post","parameters":[{"name":"X-API-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Api-Key"}},{"name":"X-RapidAPI-Key","in":"header","required":false,"schema":{"type":"string","default":"","title":"X-Rapidapi-Key"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/BatchPortfolioRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}}},"components":{"schemas":{"BatchPortfolioItem":{"properties":{"asset_id":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Asset Id"},"asset_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Asset Name"},"country":{"type":"string","title":"Country"},"building_type":{"type":"string","title":"Building Type"},"floor_area_m2":{"type":"number","exclusiveMinimum":0.0,"title":"Floor Area M2"},"annual_kwh_elec":{"type":"number","minimum":0.0,"title":"Annual Kwh Elec"},"annual_kwh_gas":{"type":"number","minimum":0.0,"title":"Annual Kwh Gas"},"year_built":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Year Built"},"annual_noi_eur":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Annual Noi Eur"},"loan_maturity_year":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Loan Maturity Year"},"loan_outstanding_eur":{"anyOf":[{"type":"number"},{"type":"null"}],"title":"Loan Outstanding Eur"}},"type":"object","required":["country","building_type","floor_area_m2","annual_kwh_elec","annual_kwh_gas"],"title":"BatchPortfolioItem"},"BatchPortfolioRequest":{"properties":{"fund_name":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"Fund Name"},"assets":{"items":{"$ref":"#/components/schemas/BatchPortfolioItem"},"type":"array","maxItems":100,"minItems":1,"title":"Assets"}},"type":"object","required":["assets"],"title":"BatchPortfolioRequest","example":{"assets":[{"annual_kwh_elec":10500,"annual_kwh_gas":60000,"annual_noi_eur":38000,"asset_id":"A001","asset_name":"10 Pratt Mews","building_type":"office","country":"uk","floor_area_m2":142,"loan_maturity_year":2027,"loan_outstanding_eur":250000,"year_built":1965}],"fund_name":"Veridian Real Estate Fund I"}},"BrownDiscountRequest":{"properties":{"country":{"type":"string","title":"Country","description":"Country code."},"building_type":{"type":"string","title":"Building Type","description":"Building type code."},"floor_area_m2":{"type":"number","exclusiveMinimum":0.0,"title":"Floor Area M2"},"annual_kwh_elec":{"type":"number","minimum":0.0,"title":"Annual Kwh Elec"},"annual_kwh_gas":{"type":"number","minimum":0.0,"title":"Annual Kwh Gas","default":0},"asking_price_eur":{"anyOf":[{"type":"number","exclusiveMinimum":0.0},{"type":"null"}],"title":"Asking Price Eur","description":"Vendor asking price in EUR. Required for adjusted bid calculation."},"annual_noi_eur":{"anyOf":[{"type":"number","exclusiveMinimum":0.0},{"type":"null"}],"title":"Annual Noi Eur","description":"Net Operating Income EUR/yr. Required for cap rate discount analysis."},"year_built":{"anyOf":[{"type":"integer","maximum":2025.0,"minimum":1800.0},{"type":"null"}],"title":"Year Built"}},"type":"object","required":["country","building_type","floor_area_m2","annual_kwh_elec"],"title":"BrownDiscountRequest","example":{"annual_kwh_elec":680000,"annual_kwh_gas":280000,"annual_noi_eur":580000,"asking_price_eur":12000000,"building_type":"office","country":"germany","floor_area_m2":5000,"year_built":1988}},"EmbodiedCarbonRequest":{"properties":{"floor_area_m2":{"type":"number","exclusiveMinimum":0.0,"title":"Floor Area M2"},"renovation_measures":{"items":{"type":"string"},"type":"array","minItems":1,"title":"Renovation Measures"},"year_built":{"anyOf":[{"type":"integer"},{"type":"null"}],"title":"Year Built"}},"type":"object","required":["floor_area_m2","renovation_measures"],"title":"EmbodiedCarbonRequest","example":{"floor_area_m2":7800,"renovation_measures":["roof_insulation","wall_insulation","heat_pump","solar_pv","led_lighting"],"year_built":1961}},"FullAnalysisRequest":{"properties":{"country":{"type":"string","title":"Country","description":"Country code."},"building_type":{"type":"string","title":"Building Type","description":"Building type code."},"floor_area_m2":{"type":"number","maximum":500